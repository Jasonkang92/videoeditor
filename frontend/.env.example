# =============================================================================
# VideoEditor - Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# Variables prefixed with VITE_ are exposed to the browser!
# =============================================================================

# =============================================================================
# API Configuration
# =============================================================================
# Backend API URL
VITE_API_URL=http://localhost:8000
VITE_API_PREFIX=/api/v1

# =============================================================================
# Public Keys (Only expose non-sensitive keys here!)
# =============================================================================
# Google Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false

# =============================================================================
# Application Settings
# =============================================================================
VITE_APP_NAME=VideoEditor
VITE_APP_VERSION=1.0.0

# =============================================================================
# Storage
# =============================================================================
# CDN URL for static assets (optional)
VITE_CDN_URL=
VITE_MEDIA_URL=http://localhost:8000/media

# =============================================================================
# Real-time / WebSocket
# =============================================================================
VITE_WS_URL=ws://localhost:8000/ws

# =============================================================================
# OAuth (if using third-party auth)
# =============================================================================
# Google OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# =============================================================================
# Build Settings
# =============================================================================
VITE_BUILD_TIMESTAMP=
VITE_GIT_COMMIT_SHA=

# =============================================================================
# NOTE: The following should NEVER be exposed to the frontend:
# - API secrets
# - Database credentials
# - JWT tokens
# - Private keys
# These should only exist in backend environment variables!
# =============================================================================
