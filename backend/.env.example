# =============================================================================
# VideoEditor - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# Application
# =============================================================================
APP_NAME=VideoEditor
APP_VERSION=1.0.0
APP_DEBUG=False
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENVIRONMENT=development

# =============================================================================
# Security
# =============================================================================
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/videoeditor
DATABASE_ECHO=False

# For local development without Docker
# DATABASE_URL=sqlite:///./videoeditor.db

# =============================================================================
# Redis (Optional - for caching and real-time features)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# =============================================================================
# CORS
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# =============================================================================
# File Storage
# =============================================================================
# Local storage (development)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=500

# Cloud storage (production)
# STORAGE_PROVIDER=gcs
# GCS_BUCKET_NAME=videoeditor-bucket
# GCS_CREDENTIALS_FILE=./google-credentials.json

# =============================================================================
# External APIs
# =============================================================================
# Google Cloud (for video processing, speech-to-text, etc.)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_PROJECT_ID=your_project_id

# =============================================================================
# Email (Optional)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# Video Processing
# =============================================================================
# FFmpeg path (if not in PATH)
FFMPEG_PATH=/usr/bin/ffmpeg
THUMBNAIL_SIZE=1280x720
VIDEO_QUALITY_PRESET=medium
